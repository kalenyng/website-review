# Copy this file to .env.local and fill in your Firebase project values.
# Run `node scripts/set-env.js` to generate environment.ts and public/review-widget.js.
# These are automatically generated on Vercel using environment variables set in the dashboard.

FIREBASE_API_KEY=replace-me
FIREBASE_AUTH_DOMAIN=replace-me
FIREBASE_DATABASE_URL=replace-me
FIREBASE_PROJECT_ID=replace-me
FIREBASE_STORAGE_BUCKET=replace-me
FIREBASE_MESSAGING_SENDER_ID=replace-me
FIREBASE_APP_ID=replace-me
FIREBASE_MEASUREMENT_ID=replace-me
